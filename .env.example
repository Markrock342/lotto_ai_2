# Supabase → Settings → Database → ใส่รหัสผ่านใน URI
# Runtime ใช้ Transaction Pooler; migrate/seed ใช้ direct connection
# โปรเจกต์ตัวอย่าง: yfthcrbsexjnvrrfifkw
DATABASE_URL="postgresql://postgres:YOUR_DB_PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.yfthcrbsexjnvrrfifkw.supabase.co:5432/postgres"

SUPABASE_URL="https://yfthcrbsexjnvrrfifkw.supabase.co"
NEXT_PUBLIC_SUPABASE_URL="https://yfthcrbsexjnvrrfifkw.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-publishable-or-anon-key"

SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# รหัสเริ่มต้นตอน seed ครั้งแรก (เปลี่ยนก่อนส่งลูกค้า)
SEED_ADMIN_PASSWORD="Admin@2026"
SEED_STAFF_PASSWORD="Staff@2026"

# Vercel Cron สำรองข้อมูลรายวัน 02:00
CRON_SECRET="random-cron-secret"

# อัปโหลด backup JSON ไป Supabase Storage (สร้าง bucket ชื่อ backups แบบ private)
# Settings → API → service_role (secret) — ใช้ backup upload เท่านั้น
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_BACKUP_BUCKET="backups"

# อ่านรูปโพยด้วย AI (แม่นกว่า OCR ในเครื่อง — สมุดลายมือ)
# ใส่อย่างใดอย่างหนึ่ง (หรือหลายตัว — ใช้ OCR_VISION_PROVIDER บังคับ)
OPENROUTER_API_KEY=""
# OPENROUTER_OCR_MODEL="openrouter/free"
# OPENROUTER_SITE_URL="http://localhost:3000"
OPENAI_API_KEY=""
# OPENAI_OCR_MODEL="gpt-4o-mini"
GEMINI_API_KEY=""
# GEMINI_OCR_MODEL="gemini-2.0-flash"
# OCR_VISION_PROVIDER="openrouter"
